<view class="dm-page home-page">
  <view class="home-hero">
    <view class="hero-copy">
      <view class="dm-eyebrow">DAIMAO SECRETARY</view>
      <view class="home-title">我替你看了一下今天</view>
      <view class="home-subtitle">你没来呆猫的时候，项目、开局和猫友消息都先放在这里。</view>
    </view>
    <view class="secretary-stage">
      <image class="secretary-frame {{activeFrame === 0 ? 'show' : ''}}" src="{{secretaryFrames[0]}}" mode="aspectFit" />
      <image class="secretary-frame {{activeFrame === 1 ? 'show' : ''}}" src="{{secretaryFrames[1]}}" mode="aspectFit" />
    </view>
  </view>

  <view class="brief-card">
    <view class="brief-title">今日简报</view>
    <view wx:if="{{loading}}" class="dm-muted">秘书正在翻记录...</view>
    <block wx:else>
      <view wx:for="{{briefLines}}" wx:key="*this" class="brief-line">
        <view class="brief-dot"></view>
        <text>{{item}}</text>
      </view>
    </block>
  </view>

  <view class="stat-grid">
    <view class="stat-card">
      <image src="/images/daimao2/notification.png" mode="aspectFit" />
      <view class="stat-number">{{stats.unread}}</view>
      <view class="stat-label">新提醒</view>
    </view>
    <view class="stat-card">
      <image src="/images/daimao2/favorite.png" mode="aspectFit" />
      <view class="stat-number">{{stats.recommended}}</view>
      <view class="stat-label">可围观</view>
    </view>
    <view class="stat-card">
      <image src="/images/daimao2/calendar.png" mode="aspectFit" />
      <view class="stat-number">{{stats.upcoming}}</view>
      <view class="stat-label">近期局</view>
    </view>
    <view class="stat-card">
      <image src="/images/daimao2/cooperation.png" mode="aspectFit" />
      <view class="stat-number">{{stats.activeProjects}}</view>
      <view class="stat-label">我的开局</view>
    </view>
  </view>

  <view class="dm-section-title">秘书建议先看</view>
  <view wx:if="{{!recommendations.length && !loading}}" class="dm-card dm-empty">
    <image src="/images/daimao2/empty.png" mode="aspectFit" />
    <view class="dm-muted">暂时没有新的项目推荐。</view>
  </view>
  <view wx:for="{{recommendations}}" wx:key="target_id" class="dm-card home-project" data-id="{{item.target_id}}" bindtap="openProject">
    <view class="dm-row">
      <image class="card-icon" src="/images/daimao2/project-task.png" mode="aspectFit" />
      <view class="dm-pill yellow">围观项目</view>
    </view>
    <view class="home-card-title">{{item.name}}</view>
    <view class="home-card-copy">{{item.reason_summary}}</view>
  </view>

  <view class="dm-section-title">最近的官方局</view>
  <view wx:for="{{events}}" wx:key="id" class="dm-card event-mini" bindtap="openEvent">
    <image class="card-icon" src="/images/daimao2/calendar.png" mode="aspectFit" />
    <view>
      <view class="home-card-title">{{item.title}}</view>
      <view class="home-card-copy">{{item.location}}</view>
    </view>
  </view>

  <view class="dm-bottom-nav">
    <view class="dm-nav-item" data-target="innings" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.innings}}" />开局</view>
    <view class="dm-nav-item" data-target="friends" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.friends}}" />猫友</view>
    <view class="dm-nav-item primary-nav" data-target="watch" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.watch}}" />围观</view>
    <view class="dm-nav-item" data-target="me" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.me}}" />我的</view>
  </view>
  <view class="secretary-float-tip">小秘书</view>
  <view class="secretary-float" bindtap="openSecretary">
    <image class="{{secretaryBubble.frame === 0 ? 'show' : ''}}" src="{{secretaryBubble.frames[0]}}" mode="aspectFit" />
    <image class="{{secretaryBubble.frame === 1 ? 'show' : ''}}" src="{{secretaryBubble.frames[1]}}" mode="aspectFit" />
  </view>
</view>
