.home-page {
  padding-top: 24rpx;
}

.home-hero {
  position: relative;
  min-height: 430rpx;
  padding: 34rpx 28rpx 0;
  border: 3rpx solid #23211f;
  border-radius: 24rpx;
  background: #f5ead8;
  box-shadow: 7rpx 7rpx 0 #23211f;
  overflow: hidden;
}

.hero-copy {
  position: relative;
  z-index: 2;
  max-width: 410rpx;
}

.home-title {
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 900;
}

.home-subtitle {
  margin-top: 14rpx;
  color: #6b6158;
  font-size: 25rpx;
  line-height: 1.55;
}

.secretary-stage {
  position: absolute;
  right: -64rpx;
  bottom: -40rpx;
  width: 410rpx;
  height: 410rpx;
}

.secretary-frame {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.18s linear;
}

.secretary-frame.show {
  opacity: 1;
}

.brief-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 3rpx solid #23211f;
  border-radius: 18rpx;
  background: #fffdfa;
  box-shadow: 6rpx 6rpx 0 #23211f;
}

.brief-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.brief-line {
  display: flex;
  gap: 14rpx;
  margin: 14rpx 0;
  color: #48413c;
  font-size: 26rpx;
  line-height: 1.5;
}

.brief-dot {
  flex: none;
  width: 18rpx;
  height: 18rpx;
  margin-top: 10rpx;
  border: 2rpx solid #23211f;
  border-radius: 50%;
  background: #ffd66b;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 28rpx 0 10rpx;
}

.stat-card {
  padding: 16rpx 8rpx;
  border: 3rpx solid #23211f;
  border-radius: 14rpx;
  background: #fffdfa;
  text-align: center;
}

.stat-card image {
  width: 50rpx;
  height: 50rpx;
}

.stat-number {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  color: #756b63;
  font-size: 20rpx;
  font-weight: 800;
}

.card-icon {
  width: 54rpx;
  height: 54rpx;
}

.home-card-title {
  margin: 16rpx 0 8rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.home-card-copy {
  color: #625b54;
  font-size: 25rpx;
  line-height: 1.55;
}

.event-mini {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
