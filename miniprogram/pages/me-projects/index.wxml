<view class="dm-page list-page">
  <view class="list-hero">
    <view class="dm-eyebrow">MY PROJECTS</view>
    <view class="dm-title">参加的项目</view>
    <view class="dm-subtitle">这里是你已经入局的项目。点进项目后，可以看进度、成员记录和项目内讨论。</view>
  </view>

  <view wx:if="{{loading}}" class="dm-loading">正在整理项目...</view>

  <view wx:elif="{{!projects.length}}" class="dm-card dm-empty">
    <image src="{{projectIcon}}" mode="aspectFit" />
    <view class="dm-section-title">还没有入局项目</view>
    <view class="dm-muted">先去围观页看看公开项目，认证后可以申请参与。</view>
  </view>

  <view wx:else class="project-list">
    <view wx:for="{{projects}}" wx:key="id" class="dm-card project-card" data-id="{{item.id}}" bindtap="openProject">
      <view class="dm-row dm-between">
        <view class="dm-row">
          <image class="mini-icon" src="{{projectIcon}}" mode="aspectFit" />
          <view class="dm-pill green">{{item.is_creator ? '我主理' : '已入局'}}</view>
        </view>
        <view class="dm-muted">{{item.status}}</view>
      </view>
      <view class="project-title">{{item.name}}</view>
      <view wx:if="{{item.tags.length}}" class="project-tags">
        <text wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      <view class="project-copy">{{item.description}}</view>
      <view class="project-meta">进入项目空间 →</view>
    </view>
  </view>
</view>
