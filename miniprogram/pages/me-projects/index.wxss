.list-hero {
  margin-bottom: 22rpx;
  padding: 30rpx 28rpx;
  border: 3rpx solid #23211f;
  border-radius: 22rpx;
  background: #f5ead8;
  box-shadow: 6rpx 6rpx 0 #23211f;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.mini-icon {
  width: 48rpx;
  height: 48rpx;
}

.project-title {
  margin: 18rpx 0 10rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.project-copy {
  color: #514b45;
  font-size: 26rpx;
  line-height: 1.6;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.project-tags text {
  padding: 6rpx 12rpx;
  border: 2rpx solid #23211f;
  border-radius: 999rpx;
  background: #fffdfa;
  color: #2d685f;
  font-size: 21rpx;
  font-weight: 900;
}

.project-meta {
  margin-top: 18rpx;
  color: #2d685f;
  font-size: 24rpx;
  font-weight: 900;
}
