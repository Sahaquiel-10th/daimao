.event-title {
  margin: 24rpx 0 12rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.event-description {
  color: #514b45;
  font-size: 27rpx;
  line-height: 1.65;
}

.event-info {
  margin: 24rpx 0;
  padding: 18rpx 0;
  border-top: 2rpx solid #ebe5dc;
  border-bottom: 2rpx solid #ebe5dc;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 10rpx 0;
  font-size: 25rpx;
  font-weight: 700;
}

.info-row image {
  width: 42rpx;
  height: 42rpx;
}

.capacity {
  color: #7b7168;
  font-size: 23rpx;
}

.event-button {
  width: 100%;
}
