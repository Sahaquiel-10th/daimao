.secretary-page {
  transform-origin: right bottom;
}

.secretary-page.closing {
  animation: secretaryPageClose 180ms ease-in forwards;
}

.secretary-topbar {
  margin-bottom: 12rpx;
}

.back-button {
  width: 150rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 3rpx solid #23211f;
  border-radius: 999rpx;
  background: #fffdfa;
  box-shadow: 3rpx 3rpx 0 #23211f;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.secretary-hero {
  display: flex;
  align-items: center;
  min-height: 230rpx;
  margin-bottom: 18rpx;
  padding: 18rpx 24rpx 18rpx 0;
  border: 4rpx solid #23211f;
  border-radius: 28rpx;
  background: #ffd66b;
  box-shadow: 7rpx 7rpx 0 #23211f;
}

.secretary-hero image {
  flex: none;
  width: 220rpx;
  height: 200rpx;
  margin-left: -18rpx;
}

.secretary-copy {
  flex: 1;
}

.secretary-title {
  font-size: 48rpx;
  line-height: 1.14;
  font-weight: 950;
}

.brief-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 3rpx solid #23211f;
  border-radius: 22rpx;
  background: #fffdfa;
}

.brief-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
  color: #403a35;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 800;
}

.brief-line:last-child {
  margin-bottom: 0;
}

.brief-dot {
  flex: none;
  width: 13rpx;
  height: 13rpx;
  margin-top: 15rpx;
  border-radius: 50%;
  background: #23211f;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.stats-row view {
  padding: 20rpx 10rpx;
  border: 3rpx solid #23211f;
  border-radius: 18rpx;
  background: #f5ead8;
  text-align: center;
}

.stats-row text {
  display: block;
  font-size: 42rpx;
  font-weight: 950;
}

.stats-row label {
  color: #776d64;
  font-size: 21rpx;
  font-weight: 900;
}

.section-row {
  margin: 34rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 950;
}

.quiet-card,
.message-card,
.recommendation-card {
  margin-bottom: 16rpx;
  padding: 24rpx 26rpx;
  border: 2rpx solid rgba(35, 33, 31, 0.22);
  border-radius: 20rpx;
  background: #fffdfa;
  color: #6b635b;
  font-size: 25rpx;
  line-height: 1.5;
}

.message-card.unread {
  border-color: #23211f;
  background: #fff6d8;
}

.action-card {
  border-radius: 22rpx;
  box-shadow: 4rpx 4rpx 0 #23211f;
}

.notice-title,
.message-title {
  margin: 18rpx 0 10rpx;
  color: #23211f;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 950;
}

.message-title {
  margin-top: 0;
  font-size: 28rpx;
}

.notice-content,
.message-content {
  color: #5f5851;
  font-size: 25rpx;
  line-height: 1.62;
}

.application-detail {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f7efe2;
  color: #6a625a;
  font-size: 24rpx;
  line-height: 1.55;
}

.request-actions,
.invitation-button {
  margin-top: 24rpx;
}

@keyframes secretaryPageClose {
  from {
    opacity: 1;
    transform: scale(1);
    border-radius: 0;
  }
  to {
    opacity: 0;
    transform: scale(0.24) translate(190rpx, 280rpx);
    border-radius: 999rpx;
  }
}
