.discover-page {
  padding-top: 42rpx;
}

.discover-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.discover-title {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 950;
  letter-spacing: -1rpx;
}

.create-button {
  width: 116rpx;
  height: 64rpx;
  border: 3rpx solid #23211f;
  border-radius: 999rpx;
  background: #ffd66b;
  box-shadow: 3rpx 3rpx 0 #23211f;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.featured-card {
  position: relative;
  margin-bottom: 34rpx;
  padding: 34rpx 32rpx 30rpx;
  border: 4rpx solid #23211f;
  border-radius: 28rpx;
  background: #f5ead8;
  box-shadow: 8rpx 8rpx 0 #23211f;
  overflow: hidden;
}

.featured-cat {
  position: absolute;
  right: -34rpx;
  bottom: -18rpx;
  width: 230rpx;
  height: 120rpx;
  opacity: 0.2;
  pointer-events: none;
}

.featured-top,
.featured-meta,
.section-row,
.project-meta,
.star-count {
  display: flex;
  align-items: center;
}

.featured-top,
.section-row {
  justify-content: space-between;
}

.featured-stars,
.star-count {
  gap: 6rpx;
  color: #9a6712;
  font-size: 25rpx;
  font-weight: 950;
}

.featured-stars image,
.star-count image {
  width: 32rpx;
  height: 32rpx;
}

.featured-title {
  position: relative;
  margin: 30rpx 0 18rpx;
  max-width: 500rpx;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 950;
}

.featured-copy {
  position: relative;
  display: -webkit-box;
  max-width: 500rpx;
  margin-top: 18rpx;
  overflow: hidden;
  color: #4f4943;
  font-size: 28rpx;
  line-height: 1.68;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.project-carousel {
  width: calc(100% + 60rpx);
  margin: 0 -30rpx 22rpx;
  white-space: nowrap;
}

.carousel-card {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  justify-content: flex-end;
  width: 330rpx;
  height: 250rpx;
  margin-left: 30rpx;
  padding: 24rpx;
  overflow: hidden;
  border: 3rpx solid #23211f;
  border-radius: 28rpx;
  background: #b9ddd4;
  box-shadow: 5rpx 5rpx 0 #23211f;
  vertical-align: top;
}

.carousel-card:nth-child(2n) {
  background: #ffd66b;
}

.carousel-card:nth-child(3n) {
  background: #f5ead8;
}

.carousel-cat {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  width: 170rpx;
  height: 150rpx;
  opacity: 0.22;
}

.carousel-count {
  margin-bottom: 10rpx;
  color: #6d645c;
  font-size: 22rpx;
  font-weight: 900;
}

.carousel-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 950;
  white-space: normal;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.carousel-tags {
  margin-top: 12rpx;
  color: #2d685f;
  font-size: 22rpx;
  font-weight: 900;
}

.featured-meta {
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
  color: #6d645c;
  font-size: 23rpx;
  font-weight: 800;
}

.featured-meta text,
.project-meta text {
  padding: 0 12rpx;
  border-left: 2rpx solid rgba(35, 33, 31, 0.2);
}

.featured-meta text:first-child,
.project-meta text:first-child {
  padding-left: 0;
  border-left: 0;
}

.section-row {
  margin: 18rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 950;
}

.section-count {
  color: #81776e;
  font-size: 22rpx;
  font-weight: 900;
}

.project-card {
  display: flex;
  gap: 22rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
  border: 3rpx solid #23211f;
  border-radius: 22rpx;
  background: #fffdfa;
  box-shadow: 4rpx 4rpx 0 #23211f;
}

.project-main {
  flex: 1;
  min-width: 0;
}

.project-title {
  margin-bottom: 10rpx;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 950;
}

.project-description {
  display: -webkit-box;
  overflow: hidden;
  color: #5f5851;
  font-size: 24rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.project-tags text {
  padding: 7rpx 13rpx;
  border: 2rpx solid #23211f;
  border-radius: 999rpx;
  background: #fffdfa;
  color: #2d685f;
  font-size: 21rpx;
  font-weight: 900;
}

.project-tags.small {
  margin-top: 16rpx;
}

.project-tags.small text {
  padding: 5rpx 11rpx;
  border-width: 1rpx;
  background: #f7efe2;
  font-size: 20rpx;
}

.project-meta {
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  color: #81776e;
  font-size: 22rpx;
}

.star-count {
  align-self: flex-start;
  flex: none;
  min-width: 72rpx;
  justify-content: flex-end;
}
