<view class="dm-page discover-page">
  <view class="discover-top">
    <view>
      <view class="dm-eyebrow">DAIMAO PROJECTS</view>
      <view class="discover-title">围观项目</view>
    </view>
    <button class="create-button" bindtap="createProject">提项目</button>
  </view>

  <view wx:if="{{loading}}" class="dm-loading">正在看看有什么新项目...</view>
  <view wx:elif="{{!projects.length}}" class="dm-card dm-empty">
    <image wx:if="{{emptySrc}}" src="{{emptySrc}}" mode="aspectFit" />
    <view class="dm-section-title">暂时没有公开项目</view>
    <view class="dm-muted">项目池正在整理。</view>
  </view>
  <block wx:else>
    <view class="featured-card" data-id="{{projects[0].id}}" bindtap="openProject">
      <image class="featured-cat" src="{{heroCat}}" mode="aspectFit" />
      <view class="featured-top">
        <view class="dm-pill yellow">正在被围观</view>
        <view class="featured-stars">
          <image src="{{icons.favorite}}" mode="aspectFit" />
          <text>{{projects[0].star_count || 0}}</text>
        </view>
      </view>
      <view class="featured-title">{{projects[0].name}}</view>
      <view wx:if="{{projects[0].tags.length}}" class="project-tags">
        <text wx:for="{{projects[0].tags}}" wx:key="*this">#{{item}}</text>
      </view>
      <view class="featured-copy">{{projects[0].description}}</view>
      <view class="featured-meta">
        <text>{{projects[0].stageLabel}}</text>
        <text>{{projects[0].watch_count || projects[0].star_count || 0}} 人围观</text>
        <text wx:if="{{projects[0].is_member}}">已入局</text>
      </view>
    </view>

    <scroll-view class="project-carousel" scroll-x enhanced show-scrollbar="{{false}}">
      <view wx:for="{{projects}}" wx:key="id" class="carousel-card" data-id="{{item.id}}" bindtap="openProject">
        <image class="carousel-cat" src="{{item.catSrc}}" mode="aspectFit" />
        <view class="carousel-count">{{item.star_count || 0}} 人围观</view>
        <view class="carousel-title">{{item.name}}</view>
        <view wx:if="{{item.tags.length}}" class="carousel-tags">#{{item.tags[0]}}</view>
      </view>
    </scroll-view>

    <view class="section-row">
      <view class="section-title">项目池</view>
      <view class="section-count">{{projects.length}} 个</view>
    </view>
  </block>
  <view
    wx:for="{{projects}}"
    wx:key="id"
    class="project-card"
    data-id="{{item.id}}"
    bindtap="openProject"
  >
    <view class="project-main">
      <view class="project-title">{{item.name}}</view>
      <view class="project-description">{{item.description}}</view>
      <view wx:if="{{item.tags.length}}" class="project-tags small">
        <text wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      <view class="project-meta">
        <text>{{item.stageLabel}}</text>
        <text>{{item.watch_count || item.star_count || 0}} 人围观</text>
        <text wx:if="{{item.is_member}}">已入局</text>
      </view>
    </view>
    <view class="star-count">
      <image src="{{icons.favorite}}" mode="aspectFit" />
      <text>{{item.star_count || 0}}</text>
    </view>
  </view>

  <view class="dm-bottom-nav">
    <view class="dm-nav-item" data-target="innings" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.innings}}" />开局</view>
    <view class="dm-nav-item" data-target="friends" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.friends}}" />猫友</view>
    <view class="dm-nav-item active primary-nav"><image class="dm-nav-icon" src="{{icons.watch}}" />围观</view>
    <view class="dm-nav-item" data-target="me" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.me}}" />我的</view>
  </view>
  <view class="secretary-float-tip">小秘书</view>
  <view class="secretary-float" bindtap="openSecretary">
    <image class="{{secretaryBubble.frame === 0 ? 'show' : ''}}" src="{{secretaryBubble.frames[0]}}" mode="aspectFit" />
    <image class="{{secretaryBubble.frame === 1 ? 'show' : ''}}" src="{{secretaryBubble.frames[1]}}" mode="aspectFit" />
  </view>
</view>
