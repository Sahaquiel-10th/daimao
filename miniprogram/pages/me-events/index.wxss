.list-hero {
  margin-bottom: 22rpx;
  padding: 30rpx 28rpx;
  border: 3rpx solid #23211f;
  border-radius: 22rpx;
  background: #f5ead8;
  box-shadow: 6rpx 6rpx 0 #23211f;
}

.event-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.mini-icon {
  width: 48rpx;
  height: 48rpx;
}

.event-title {
  margin: 18rpx 0 10rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.event-copy {
  color: #514b45;
  font-size: 26rpx;
  line-height: 1.6;
}

.event-meta {
  margin-top: 18rpx;
  color: #81776e;
  font-size: 23rpx;
}
