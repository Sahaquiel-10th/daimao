<view class="dm-page innings-page">
  <view class="dm-header">
    <view>
      <view class="dm-eyebrow">START / JOIN</view>
      <view class="dm-title">开局</view>
      <view class="dm-subtitle">这里是你已入局的项目。项目进度、成员记录和对外围观更新，都在项目空间里完成。</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="dm-loading">正在找你的项目...</view>
  <block wx:else>
    <view wx:if="{{!projects.length}}" class="dm-card dm-empty">
      <image src="{{icons.empty}}" mode="aspectFit" />
      <view class="dm-section-title">你还没有入局项目</view>
      <view class="dm-muted">项目由官方或营主发布。通过社区认证后，可以去围观页申请参与公开项目。</view>
    </view>
    <view wx:for="{{projects}}" wx:key="id" class="dm-card project-card" data-id="{{item.id}}" bindtap="openProject">
      <view class="dm-row dm-between">
        <view class="dm-row">
          <image class="mini-icon" src="{{icons.innings}}" mode="aspectFit" />
          <view class="dm-pill green">{{item.is_creator ? '我主理' : '已入局'}}</view>
        </view>
        <view class="dm-muted">{{item.status}}</view>
      </view>
      <view class="project-title">{{item.name}}</view>
      <view wx:if="{{item.tags.length}}" class="project-tags">
        <text wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
      </view>
      <view class="project-copy">{{item.description}}</view>
      <view class="project-meta">项目空间 · 进度同步 · 成员讨论 →</view>
    </view>
  </block>

  <view class="dm-bottom-nav">
    <view class="dm-nav-item active"><image class="dm-nav-icon" src="{{icons.innings}}" />开局</view>
    <view class="dm-nav-item" data-target="friends" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.friends}}" />猫友</view>
    <view class="dm-nav-item primary-nav" data-target="watch" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.watch}}" />围观</view>
    <view class="dm-nav-item" data-target="me" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.me}}" />我的</view>
  </view>
  <view class="secretary-float-tip">小秘书</view>
  <view class="secretary-float" bindtap="openSecretary">
    <image class="{{secretaryBubble.frame === 0 ? 'show' : ''}}" src="{{secretaryBubble.frames[0]}}" mode="aspectFit" />
    <image class="{{secretaryBubble.frame === 1 ? 'show' : ''}}" src="{{secretaryBubble.frames[1]}}" mode="aspectFit" />
  </view>
</view>
