.create-button {
  width: 112rpx;
  height: 72rpx;
  border: 3rpx solid #23211f;
  border-radius: 999rpx;
  background: #ffd66b;
  box-shadow: 4rpx 4rpx 0 #23211f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.innings-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-bottom: 26rpx;
  padding: 8rpx;
  border: 3rpx solid #23211f;
  border-radius: 14rpx;
  background: #fffdfa;
}

.innings-tabs view {
  height: 70rpx;
  border-radius: 9rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 70rpx;
  text-align: center;
}

.innings-tabs .active {
  background: #23211f;
  color: #fffdfa;
}

.mini-icon {
  width: 48rpx;
  height: 48rpx;
}

.project-title {
  margin: 18rpx 0 10rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.project-copy {
  color: #514b45;
  font-size: 26rpx;
  line-height: 1.6;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.project-tags text {
  padding: 6rpx 12rpx;
  border: 2rpx solid #23211f;
  border-radius: 999rpx;
  background: #fffdfa;
  color: #2d685f;
  font-size: 21rpx;
  font-weight: 900;
}

.project-meta {
  margin-top: 18rpx;
  color: #81776e;
  font-size: 23rpx;
}

.event-button {
  width: 100%;
  margin-top: 24rpx;
}
