page {
  min-height: 100vh;
  background: #faf7f1;
  color: #23211f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

button::after {
  border: none;
}

.tag-entry-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx;
  overflow: hidden;
}

.brand-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0 54rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border: 3rpx solid #23211f;
  border-radius: 50%;
  background: #ffd66b;
  box-shadow: 4rpx 4rpx 0 #23211f;
  color: #23211f;
  font-size: 42rpx;
  font-weight: 900;
}

.brand-title {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 800;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: #78716a;
  font-size: 25rpx;
}

.entry-card {
  position: relative;
  z-index: 1;
  min-height: 560rpx;
  padding: 112rpx 30rpx 34rpx;
  border: 3rpx solid #23211f;
  border-radius: 16rpx;
  background: #fffdfa;
  box-shadow: 7rpx 7rpx 0 #23211f;
  text-align: center;
}

.entry-cat {
  position: absolute;
  top: -92rpx;
  right: 18rpx;
  width: 186rpx;
  height: 160rpx;
}

.loader {
  width: 58rpx;
  height: 58rpx;
  margin: 48rpx auto 28rpx;
  border: 7rpx solid #ece6dc;
  border-top-color: #9fcfc3;
  border-radius: 50%;
}

.badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border: 3rpx solid #23211f;
  border-radius: 999rpx;
  background: #f5ead8;
  font-size: 24rpx;
  font-weight: 800;
}

.badge.success {
  background: #9fcfc3;
}

.badge.error {
  background: #f2b8a2;
}

.entry-title {
  margin-top: 28rpx;
  font-size: 38rpx;
  line-height: 1.28;
  font-weight: 800;
}

.entry-message {
  margin: 20rpx auto 0;
  max-width: 560rpx;
  color: #6f6a63;
  font-size: 27rpx;
  line-height: 1.55;
}

.agreement-check {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 28rpx;
  color: #5f5850;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: left;
}

.agreement-checkbox {
  transform: scale(0.78);
  transform-origin: left top;
}

.agreement-text {
  flex: 1;
}

.agreement-link {
  color: #2f6f63;
  font-weight: 800;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 92rpx;
  margin-top: 34rpx;
  border: 3rpx solid #23211f;
  border-radius: 8rpx;
  box-shadow: 5rpx 5rpx 0 #23211f;
  color: #23211f;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.primary-button {
  background: #ffd66b;
}

.secondary-button {
  background: #ffffff;
}

.button-press {
  transform: translate(5rpx, 5rpx);
  box-shadow: 0 0 0 #23211f;
}
