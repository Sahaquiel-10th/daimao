<view class="dm-page me-page">
  <view class="dm-card profile-card primary-profile">
    <image class="profile-cat" src="{{icons.profileCat}}" mode="aspectFit" />
    <view class="profile-main">
      <view class="profile-name">{{profile.name || '还没有保存名片'}}</view>
      <view class="dm-muted">{{profile.job || '先补一张名片，碰一碰时才有东西递出去'}}</view>
      <view class="profile-badge-row">
        <view wx:if="{{level.name}}" class="profile-level" style="color: {{level.levelColor}}; border-color: {{level.levelColor}};">{{level.name}}</view>
        <view class="level-help-button" bindtap="openLevelHelp">?</view>
        <view class="role-badge small">{{identity.isCommunityMember ? '已认证' : '未认证'}}</view>
      </view>
      <view wx:if="{{identity.communities.length}}" class="community-list compact">
        <view wx:for="{{identity.communities}}" wx:key="id" class="community-badge">
          <image wx:if="{{item.logoUrl}}" src="{{item.logoUrl}}" mode="aspectFill" />
          <text>{{item.badge || item.name}}</text>
        </view>
      </view>
      <view wx:else class="community-hint">通过社区认证后，可以申请参与公开项目。</view>
    </view>
    <view class="profile-actions">
      <button class="mini-button" bindtap="previewCard">预览</button>
      <button class="mini-button primary" bindtap="editCard">编辑</button>
    </view>
  </view>

  <view wx:if="{{showLevelHelp}}" class="modal-mask" bindtap="closeLevelHelp">
    <view class="level-modal" catchtap="noop">
      <view class="modal-title">等级说明</view>
      <view class="qa-title">问：如何提升等级？</view>
      <view class="qa-copy">答：通过保存名片、线下互换名片、提交项目申请、被项目接纳参与、参与项目并顺利完成等动作提升。</view>
      <view class="rule-chip-wrap">
        <view wx:for="{{experienceRules}}" wx:key="key" class="rule-chip">{{item.label}}</view>
      </view>
      <button class="dm-primary full-button" bindtap="closeLevelHelp">知道了</button>
    </view>
  </view>

  <button class="dm-primary secretary-button" bindtap="openAgentSettings">秘书怎么帮我</button>

  <view class="dm-card record-card">
    <view class="dm-section-title inline-title">我的记录</view>
    <view class="record-grid">
      <view class="record-entry" data-target="records" bindtap="openRecordPage">
        <image src="{{icons.friends}}" mode="aspectFit" />
        <view>过往动态</view>
        <text>碰一碰、记录和提醒</text>
      </view>
      <view class="record-entry" data-target="projects" bindtap="openRecordPage">
        <image src="{{icons.innings}}" mode="aspectFit" />
        <view>参加的项目</view>
        <text>打开项目列表，再进入协作空间</text>
      </view>
      <view class="record-entry" data-target="events" bindtap="openRecordPage">
        <image src="{{icons.calendar}}" mode="aspectFit" />
        <view>参加的活动</view>
        <text>查看报名和活动记录</text>
      </view>
    </view>
  </view>

  <view class="dm-bottom-nav">
    <view class="dm-nav-item" data-target="innings" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.innings}}" />开局</view>
    <view class="dm-nav-item" data-target="friends" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.friends}}" />猫友</view>
    <view class="dm-nav-item primary-nav" data-target="watch" bindtap="goNav"><image class="dm-nav-icon" src="{{icons.watch}}" />围观</view>
    <view class="dm-nav-item active"><image class="dm-nav-icon" src="{{icons.me}}" />我的</view>
  </view>
  <view class="secretary-float-tip">小秘书</view>
  <view class="secretary-float" bindtap="openSecretary">
    <image class="{{secretaryBubble.frame === 0 ? 'show' : ''}}" src="{{secretaryBubble.frames[0]}}" mode="aspectFit" />
    <image class="{{secretaryBubble.frame === 1 ? 'show' : ''}}" src="{{secretaryBubble.frames[1]}}" mode="aspectFit" />
  </view>
</view>
