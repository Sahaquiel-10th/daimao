.me-hero {
  display: flex;
  align-items: center;
  min-height: 250rpx;
  margin-bottom: 22rpx;
  padding: 20rpx 24rpx;
  border: 3rpx solid #23211f;
  border-radius: 20rpx;
  background: #f5ead8;
  box-shadow: 6rpx 6rpx 0 #23211f;
}

.me-cat {
  flex: none;
  width: 220rpx;
  height: 210rpx;
  margin-left: -34rpx;
}

.me-copy {
  flex: 1;
}

.profile-card,
.compact-card,
.timeline-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-icon,
.compact-card image,
.timeline-item image {
  flex: none;
  width: 62rpx;
  height: 62rpx;
}

.profile-main {
  flex: 1;
}

.profile-name,
.compact-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.arrow {
  font-size: 48rpx;
}

.secretary-button {
  width: 100%;
}

.level-card {
  margin-bottom: 22rpx;
}

.level-name {
  margin-bottom: 8rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.role-badge {
  padding: 10rpx 18rpx;
  border: 3rpx solid #23211f;
  border-radius: 999rpx;
  background: #ffd66b;
  box-shadow: 3rpx 3rpx 0 #23211f;
  font-size: 23rpx;
  font-weight: 900;
}

.level-bar {
  height: 18rpx;
  margin: 22rpx 0 12rpx;
  overflow: hidden;
  border: 2rpx solid #23211f;
  border-radius: 999rpx;
  background: #efe4d2;
}

.level-bar view {
  height: 100%;
  border-radius: 999rpx;
  background: #9fcfc3;
}

.level-next,
.community-hint {
  color: #655e57;
  font-size: 23rpx;
}

.community-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.community-list text {
  padding: 8rpx 14rpx;
  border: 2rpx solid #23211f;
  border-radius: 999rpx;
  background: #fffdfa;
  color: #2d685f;
  font-size: 22rpx;
  font-weight: 900;
}

.inline-title {
  margin: 0 0 12rpx;
}

.rule-line {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed rgba(35, 33, 31, 0.28);
  color: #554d46;
  font-size: 24rpx;
}

.rule-line:last-child {
  border-bottom: 0;
}

.timeline-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  color: #554d46;
  font-size: 25rpx;
  line-height: 1.5;
}
